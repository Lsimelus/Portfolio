l},{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"62","messages":"63","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"64","messages":"65","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/index.tsx",[],["66","67"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/reportWebVitals.ts",[],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/App.tsx",["68","69"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Page.tsx",["70","71","72"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Button.tsx",["73","74","75","76"],"import React from \"react\";\nimport  styled  from  'styled-components';\nimport {Link} from 'react-scroll'\nimport Theme from \"./Theme\";\n\nconst ButtonLayout = styled.button<{color: string, background: string}>`\n  background-color: ${props => props.background};\n  border: none;\n  color: ${props => props.color};\n  padding: 8px 16px;\n  text-align: center;\n  font-size: 16px;\n  margin: 4px 2px;\n  opacity: 0.6;\n  transition: 0.3s;\n  display: inline-block;\n  text-decoration: none;\n  cursor: pointer;\n  border-radius: 8px;\n  \n    \n  :hover {\n    opacity: 1;\n    transform: translateY(8px);\n  }\n  \n  :active {\n    opacity: .1;\n  }\n  \n  }`;\n\nexport const FormButtonComponent: React.FunctionComponent<{text_: string, background_?: string, color_?: string }> = ({ background_ , text_, color_, children }) => (\n    <ButtonLayout type={\"submit\"} form={\"contact\"} background={ background_ == undefined ? Theme.color.primary : background_ } color={ color_ == undefined ? Theme.color.secondary : color_ } >\n        {text_}\n    </ButtonLayout>\n);\n\nexport const ButtonComponent: React.FunctionComponent<{ isDownload_?: boolean, text_: string, background_?: string, color_?: string, link_: string, }> = ({ isDownload_,background_ , text_, color_, link_,  children }) => (\n        <ButtonLayout background={ background_ == undefined ? Theme.color.secondary : background_ } color={ color_ == undefined ? Theme.color.primary : color_ } >\n            {isDownload_ ?\n                <a href={link_} download>\n                        {text_}\n                </a>\n                :\n                <Link to={link_} spy={true} smooth={true}>\n                {text_}\n            </Link>\n\n            }\n        </ButtonLayout>\n);","/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Form.tsx",["77","78"],"import React, { Component } from \"react\";\nimport  styled  from  'styled-components';\nimport { FormButtonComponent} from \"./Button\";\nimport Theme from \"./Theme\";\n\nconst FormLayout = styled.form <{}>`\n    width: 42%;\n    float: right;\n    padding: 20px;\n    border: 2px solid ${Theme.color.aqua};\n    top: 0;\n    min-height: 38vh;\n    background-color: ${Theme.color.darkblue};\n    border-radius: 15px;\n    }`;\n\n\nconst InputLayout = styled.input <{}>`\n    font-size: 1em;\n    border-radius: 3px;\n    padding: 12px;\n    box-sizing: border-box;\n    word-break: break-word;\n    display: block;\n    \n    width: 100%;\n    padding: 12px;\n    border: 1px solid #ccc;\n    border-radius: 4px;\n    box-sizing: border-box;\n    margin-top: 6px;\n    margin-bottom: 16px;\n    text-align: left;\n    height: 3.5vh;\n    \n    }`;\n\nconst MessageInputLayout = styled(InputLayout) <{}>`\n    height: 10vh;\n    }`;\n\n\nexport const FormComponent: React.FunctionComponent = ({  children }) => {\n\n    const [email, setEmail] = React.useState(\"\");\n    const [name, setName] = React.useState(\"\");\n    const [phone, setPhone] = React.useState(\"\");\n    const [message, setMessage] = React.useState(\"\");\n\n    const handleSubmit = async (event: any) => {\n\n        event.preventDefault();\n        try {\n            const body = {email, name, phone, message}\n            const response = await fetch(\"http://localhost:5000/todos\",\n                {\n                    method: \"POST\",\n                    headers: { \"Content-Type\":\n                    \"application/json\" },\n                    body: JSON.stringify(body)\n                });\n            setPhone(\"\");\n            setMessage(\"\");\n            setEmail(\"\");\n            setMessage(\"\");\n            alert(\"Submitted! I will be in touch as soon as possible.\");\n\n        } catch (e) {\n            console.error(e.message)\n        }\n        console.log(`\n      Email: ${email}\n      Name: ${name}\n      Phone: ${phone}\n      Message: ${message}\n    `);\n\n    }\n\n\n    return (\n\n        <FormLayout id={\"contact\"} onSubmit={handleSubmit}>\n                <InputLayout\n                    name=\"email\"\n                    type=\"email\"\n                    value={email}\n                    onChange={e => setEmail(e.target.value)}\n                    placeholder={\"Email*\"}\n                    required />\n                <InputLayout\n                    name=\"name\"\n                    type=\"name\"\n                    value={name}\n                    placeholder={\"Name\"}\n                    onChange={e => setName(e.target.value)}/>\n\n                <InputLayout\n                    name=\"tel\"\n                    type=\"tel\"\n                    value={phone}\n                    placeholder={\"Phone #\"}\n                    onChange={e => setPhone(e.target.value)}/>\n\n                <MessageInputLayout\n                    name=\"message\"\n                    type=\"message\"\n                    value={message}\n                    placeholder={\"Message*\"}\n                    onChange={e => setMessage(e.target.value)}\n                    required />\n\n\n            <FormButtonComponent text_={\"Submit contact info\"} />\n\n        </FormLayout>\n    );\n}","/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Nav.tsx",[],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Footer.tsx",[],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Theme.tsx",["79"],"import React from \"react\";\n\nexport const Theme = {\n    \"color\" :\n        {\n            \"primaryy\": \"\",\n            \"secondaryy\": \"#00008b\",\n            \"tertiary\": \"#788890\",\n            \"background1\": \"#f5fffa\",\n            \"background2\": \"#f5f5f5\",\n            \"gray\": \"#676767\",\n            \"aqua\": \"#00FFFF\",\n            \"lightblue\": \"#8f94fb\",\n            \"blue\": \"#4e54c8\",\n            \"darkblue\": \"#00008b\",\n\n        },\n    \"font\":\n        {\n            \"title\": \"large\",\n            \"text\": \"medium\",\n            \"description\": \"small\"\n        }\n}\n\nexport default Theme;","/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Contact.tsx",["80","81"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/ImageComponent.tsx",["82","83","84","85","86","87","88"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/About.tsx",["89"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Portfolio.tsx",[],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Modal.tsx",["90"],"/Users/lyndberghsimelus/Desktop/MyPortfolio/src/main/myfrontend/src/Data.tsx",["91"],{"ruleId":"92","replacedBy":"93"},{"ruleId":"94","replacedBy":"95"},{"ruleId":"96","severity":1,"message":"97","line":5,"column":9,"nodeType":"98","messageId":"99","endLine":5,"endColumn":22},{"ruleId":"96","severity":1,"message":"100","line":12,"column":10,"nodeType":"98","messageId":"99","endLine":12,"endColumn":26},{"ruleId":"101","severity":1,"message":"102","line":40,"column":50,"nodeType":"103","messageId":"104","endLine":40,"endColumn":52},{"ruleId":"101","severit